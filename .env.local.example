# ─── Neon PostgreSQL ───────────────────────────────────────
# Dapatkan dari: https://neon.tech → project → Connection string
DATABASE_URL="postgresql://user:password@ep-xxx.neon.tech/neondb?sslmode=require"

# ─── Admin ─────────────────────────────────────────────────
# Password untuk login ke /admin — ganti dengan password kuat
ADMIN_PASSWORD="ganti_password_kamu"

# Secret untuk JWT-like token — string random panjang, bebas isinya
AUTH_SECRET="ganti_dengan_random_string_panjang_minimal_32_karakter"
